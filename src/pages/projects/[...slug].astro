---
import { Picture } from "astro:assets";
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "~/layouts/Layout.astro";
import { AUTHOR_NAME, AUTHOR_IMAGE, AUTHOR_DESCRIPTION } from "~/consts";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: project,
  }));
}
type Props = CollectionEntry<"projects">;

const url = new URL(Astro.url.pathname.replace(".html", ""), Astro.url.origin);
const project = Astro.props;
const { Content } = await project.render();
---

<Layout
  title={`${project.data.title} • ${AUTHOR_NAME}`}
  description={project.data.description}
  image={project.data.image}>

  <Fragment slot="structured-data">
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [{
        "@type": "ListItem",
        "position": 1,
        "name": AUTHOR_NAME,
        "item": "https://www.toddhgardner.com/"
      },{
        "@type": "ListItem",
        "position": 2,
        "name": "Projects",
        "item": "https://www.toddhgardner.com/projects"
      },{
        "@type": "ListItem",
        "position": 3,
        "name": project.data.title
      }]
    })} />
  </Fragment>

  <style>
    article {
      padding-top: 0;
      header {
        nav {
          font-size: 0.8em;
        }
        picture {
          padding: 16px;
          background-color: white;
        }
        picture img {
          border-radius: var(--pico-border-radius);
        }
      }
      footer {
        .about {
          padding: 16px 0;
          display: flex;
          gap: 32px;
          picture {
            flex: 0 0 120px;
            img {
              border-radius: 100%;
            }
          }
          p {
            font-size: 0.9em;
          }
        }
      }
      @media(max-width: 768px) {
        margin-right: calc(-1 * var(--pico-spacing));
        margin-left: calc(-1 * var(--pico-spacing));
        footer {
          .about {
            picture {
              display: none;
            }
          }
        }
      }
    }
  </style>

  <article class="max-text-width">
    <nav aria-label="breadcrumb">
      <ul>
        <li><a href={new URL("/", Astro.url.origin)} class="unlink">Home</a></li>
        <li><a href={new URL("/projects", Astro.url.origin)} class="unlink">Projects</a></li>
      </ul>
    </nav>

    <header class="flex-column flex-gap-24">
      {project.data.image && (
        <Picture
          src={project.data.image}
          alt={project.data.title}
          formats={["webp"]}
          widths={[900, 1800]}
          loading="eager"
        />
      )}
      <h1>{project.data.title}</h1>
      <div class="color-secondary">{project.data.subtitle}</div>
      <div class="flex flex-wrap flex-gap-8">
        <time datetime={project.data.startedOn.toISOString()}>
          {project.data.startedOn.toLocaleDateString()}
        </time>
        →
        {project.data.completedOn ? (
          <time datetime={project.data.completedOn.toISOString()}>
            {project.data.completedOn.toLocaleDateString()}
          </time>
        ) : "Present"}
        •
        <a href={project.data.url}>{new URL(project.data.url).hostname}</a>
      </div>
    </header>
    <Content />
    <div style="text-align: center; margin-top: 32px;">
      <a role="button" href={project.data.url}>Visit {project.data.title}</a>
    </div>
    <footer>
      <section class="about grid">
        <Picture src={AUTHOR_IMAGE} formats={["webp"]}
          alt={AUTHOR_NAME}
          width={120} />
        <div>
          <h3>About the author</h3>
          <p>{AUTHOR_DESCRIPTION}</p>
          <p><a href={new URL("about", Astro.url.origin)} title={AUTHOR_NAME}>More about Todd &gt;&gt;</a></p>
        </div>
      </section>
    </footer>
  </article>
</Layout>
